{
  "name": "@moonlight-protocol/provider-platform",
  "version": "0.2.0",
  "license": "MIT",
  "exports": "./src/main.ts",
  "tasks": {
    "serve": "deno run --allow-all --unstable-kv src/main.ts",
    "db:generate": "deno -A --node-modules-dir npm:drizzle-kit generate",
    "db:migrate": "deno -A --node-modules-dir npm:drizzle-kit migrate",
    "db:push": "deno -A --node-modules-dir npm:drizzle-kit push",
    "db:studio": "deno -A --node-modules-dir npm:drizzle-kit studio"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@/": "./src/",
    "@colibri/core": "jsr:@colibri/core@^0.6.0",
    "@fifo/convee": "jsr:@fifo/convee@^0.9.2",
    "@moonlight/moonlight-sdk": "jsr:@moonlight/moonlight-sdk@^0.3.0",
    "@types/pg": "npm:@types/pg@^8.15.6",
    "drizzle-kit": "npm:drizzle-kit@^0.31.6",
    "drizzle-orm": "npm:drizzle-orm@^0.44.7",
    "pg": "npm:pg@^8.16.3",
    "stellar-sdk": "npm:@stellar/stellar-sdk@14.2.0",

    "dotenv": "https://deno.land/std@0.224.0/dotenv/mod.ts",
    "buffer": "npm:buffer@^6.0.3",
    "asn1js": "npm:asn1js@3.0.5",
    "@oak/oak": "jsr:@oak/oak@^17.1.4",
    "@olli/kvdex": "jsr:@olli/kvdex@^3.1.4",
    "zod": "npm:zod@3.24.2",
    "@fifo/spp-sdk": "jsr:@fifo/spp-sdk@^0.1.9"
  },
  "deploy": {
    "project": "159af174-b645-4039-be9c-493de4886f26",
    "exclude": ["**/node_modules"],
    "include": [],
    "entrypoint": "src/main.ts"
  }
}
