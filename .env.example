# Environment variables for provider-platform.
#
# Rule: this file (and the platform itself) only declares INFRASTRUCTURE
# and OPERATIONAL config — never application state. Privacy Provider keys,
# council references, and contract IDs are stored in the database via the
# dashboard API and the council join flow, not via env vars.
#
# See README.md §Environment variables for full semantics (required vs
# optional, defaults, format, how-to-obtain).

# ENVIRONMENT
PORT=3000
MODE=development
LOG_LEVEL=TRACE # FATAL, ERROR, WARN, INFO, DEBUG, TRACE

# DATABASE
DATABASE_URL=postgresql://admin:devpass@localhost:5432/provider_platform_db

# STELLAR
NETWORK=testnet
NETWORK_FEE=1000000000 # stroops
# STELLAR_RPC_URL=                 # override per-network default (see README)
TRANSACTION_EXPIRATION_OFFSET=1000 # ledger sequences; ~83min on testnet

# SERVICE
SERVICE_DOMAIN=localhost
SERVICE_AUTH_SECRET= # base64(32 random bytes). JWT signing AND at-rest PP-key
                    # encryption. Omit to randomly generate (dev only).
# PROVIDER_BASE_URL=               # externally reachable base URL; default http://localhost:$PORT

# AUTH
CHALLENGE_TTL=900 # 15m — challenge-response window for SEP-43/53 auth
SESSION_TTL=21600 # 6h — JWT session lifetime

# MEMPOOL
MEMPOOL_SLOT_CAPACITY=100
MEMPOOL_EXPENSIVE_OP_WEIGHT=10
MEMPOOL_CHEAP_OP_WEIGHT=1
MEMPOOL_EXECUTOR_INTERVAL_MS=5000
MEMPOOL_VERIFIER_INTERVAL_MS=10000
MEMPOOL_TTL_CHECK_INTERVAL_MS=60000
MEMPOOL_MAX_RETRY_ATTEMPTS=3
# MEMPOOL_STARTUP_MAX_BUNDLE_AGE_MS=0  # >0 auto-expires stale bundles on boot

# BUNDLE
BUNDLE_MAX_OPERATIONS=20

# EVENT WATCHER
# EVENT_WATCHER_INTERVAL_MS=30000

# CORS — comma-separated allowed origins (localhost always allowed when MODE=development)
# ALLOWED_ORIGINS=https://provider-testnet.moonlightprotocol.io,https://council-testnet.moonlightprotocol.io

# OPENTELEMETRY (opt-in; read by the Deno runtime, not by app code)
# OTEL_DENO=true
# OTEL_SERVICE_NAME=provider-platform
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>  # Grafana Cloud Tempo etc.

# WAITLIST (optional)
# DISCORD_WEBHOOK_URL=             # fired (best-effort) on POST /api/v1/waitlist

# Internal: forces /pay/demo/simulate-kyc open on non-local NETWORKs. Self-hosters: leave unset.
# PAY_DEMO_ENABLED=true
